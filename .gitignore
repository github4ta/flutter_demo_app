# Временные файлы Flutter и Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/

# Файлы конфигурации Android (локальные пути к SDK)
android/local.properties
android/key.properties
android/app/*.jks
android/app/*.keystore
android/app/*.pub
android/bundle-safe-decode.json

# Файлы конфигурации iOS (зависимости и логи)
ios/Pods/
ios/.symlinks/
ios/Flutter/Debug.xcconfig
ios/Flutter/Release.xcconfig
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*

# Настройки IDE (IntelliJ, VS Code)
.idea/
*.iml
*.iws
.vscode/
.history/

# Системные файлы
.DS_Store
Thumbs.db

# Секретные файлы (токены, ключи)
.env*
